# Copiá este archivo a ".env.local" para desarrollo local, y cargá las
# mismas variables en el dashboard de Vercel para producción.

# Usuario con el que vas a iniciar sesión (no es un email, es un usuario simple)
AUTH_USER=admin

# Hash bcrypt de tu contraseña, codificado en base64 (así viaja sin problemas
# aunque el archivo .env o el panel de variables interprete el signo "$").
# Generalo con: npm run hash-password
AUTH_PASSWORD_HASH=

# Secreto para firmar las sesiones (JWT). Generalo con: openssl rand -base64 32
JWT_SECRET=

# Credenciales de Turso (dejalas vacías para desarrollo local: se usa
# automáticamente un archivo local.db en su lugar).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
